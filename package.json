{
	"name": "vite-react-template",
	"description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
	"private": true,
	"cloudflare": {
		"label": "Vite React Template",
		"products": [
			"Workers"
		],
		"categories": [],
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/532a5378-9717-4964-385b-5fafd2160200/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/ec7f4be5-d1d6-4e94-0851-126341745400/preview",
		"publish": true
	},
	"dependencies": {
		"@better-auth/passkey": "^1.6.0",
		"@rocicorp/zero": "^1.0.0",
		"ansi-escapes": "^7.1.1",
		"better-auth": "^1.6.0",
		"drizzle-orm": "^0.45.2",
		"hono": "4.8.2",
		"js-cookie": "^3.0.5",
		"pg": "^8.20.0",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"resend": "^6.10.0",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@cloudflare/vite-plugin": "1.13.13",
		"@eslint/js": "9.29.0",
		"@types/js-cookie": "^3.0.6",
		"@types/node": "24.0.4",
		"@types/pg": "^8.20.0",
		"@types/react": "19.0.10",
		"@types/react-dom": "19.0.4",
		"@vitejs/plugin-react": "5.0.0",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "9.27.0",
		"eslint-plugin-react-hooks": "5.2.0",
		"eslint-plugin-react-refresh": "0.4.20",
		"globals": "16.2.0",
		"prettier": "^3.8.1",
		"typescript": "5.8.3",
		"typescript-eslint": "8.35.0",
		"vite": "^6.0.0",
		"wait-on": "^9.0.4",
		"wrangler": "4.43.0"
	},
	"scripts": {
		"build": "tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "tsc && vite build && wrangler deploy --dry-run",
		"db:clean": "docker compose -f db/docker-compose.yml down -v && rm -rf .zero-replica*",
		"db:down": "docker compose -f db/docker-compose.yml down",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"deploy": "wrangler deploy",
		"dev": "concurrently \"pnpm:dev:* \"",
		"dev:db-up": "docker compose -f db/docker-compose.yml up -d",
		"dev:ui": "vite",
		"dev:zero-cache": "wait-on tcp:5432 && zero-cache-dev",
		"lint": "eslint . && prettier -c .",
		"format": "eslint . --fix && prettier -w .",
		"preview": "npm run build && vite preview"
	},
	"type": "module",
	"packageManager": "pnpm@10.28.1"
}
